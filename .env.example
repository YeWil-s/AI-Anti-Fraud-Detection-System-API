# Application
APP_NAME=AI Anti-Fraud Detection System
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# Database
# MySQL (本地开发)
DATABASE_URL=mysql+aiomysql://root:123456@localhost:3306/ai_fraud_detection

# PostgreSQL (云上线时使用)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_fraud_detection

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False
MINIO_BUCKET_NAME=fraud-detection

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# SMS Service (阿里云/腾讯云)
SMS_ACCESS_KEY=your-sms-access-key
SMS_SECRET_KEY=your-sms-secret-key

# Email Service (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=True
EMAIL_FROM=noreply@antifraud.com
EMAIL_FROM_NAME=AI反诈系统

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AI Models Path
VOICE_MODEL_PATH=./models/voice_detection.onnx
VIDEO_MODEL_PATH=./models/xception/deepfake_xception_lstm.onnx
# 安装 onnxruntime-gpu 后视频 ONNX 用 GPU；多卡时改为 1、2…
ONNX_GPU_DEVICE_ID=0
# 视频多窗聚合：trimmed_mean | iqr_mean | mean | median | latest
VIDEO_WINDOWS_AGGREGATE=trimmed_mean
VIDEO_WINDOWS_TRIM=0.1
TEXT_MODEL_PATH=./models/text_detection

# WebSocket
WS_HEARTBEAT_INTERVAL=30
