# =============================================================================
# 与仓库根目录 .env 结构一致；复制为 .env 后填写真实值。勿提交 .env。
# 评委「只连答辩方远程服务」时：通常无需本文件；仅需改 admin-frontend 的 API 地址。
# =============================================================================

# --- Application ---
APP_NAME=AI Anti-Fraud Detection System
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=请替换为随机长字符串

# --- Database（仅后端进程读取；管理后台浏览器不读）---
# 本机 + Compose 映射 MySQL 3307→3306：
DATABASE_URL=mysql+aiomysql://root:123456@localhost:3307/ai_fraud_detection
# 使用 docker compose --profile api 且 MySQL 在同一 compose 内时，改为：
# DATABASE_URL=mysql+aiomysql://root:123456@mysql:3306/ai_fraud_detection
# 连接答辩方远程 MySQL（由答辩方单独提供账号与地址时）：
# DATABASE_URL=mysql+aiomysql://用户:密码@答辩方主机:端口/ai_fraud_detection

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
# API 在 Docker compose 内运行时改为（与下方 CELERY 一致）：
# REDIS_URL=redis://redis:6379/0

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
# API 在 Docker compose 内运行时改为：
# MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False
MINIO_BUCKET_NAME=fraud-detection

# --- JWT ---
JWT_SECRET_KEY=请替换为随机长字符串
JWT_ALGORITHM=HS256
# 管理后台自助注册时必填的密钥（与代码默认值一致时可省略；生产环境务必单独设置）
ADMIN_REGISTER_SECRET=w5s45w4fs6dv1df5mujkb5xf2b1cxc9ds62
# 登录后令牌有效时长（分钟）。43200≈30 天；需更短更安全可改小，需「长期不关」可改大
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# --- SMS（示例占位；不用可保留占位）---
SMS_ACCESS_KEY=
SMS_SECRET_KEY=

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# API 在 Docker compose 内运行时改为：
# CELERY_BROKER_URL=redis://redis:6379/1
# CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- AI Models Path（相对项目根；镜像内工作目录为 /app）---
VOICE_MODEL_PATH=./models/voice_detection.onnx
AASIST_MODEL_PATH=./models/aasist/weights/best.pth
VIDEO_MODEL_PATH=./models/xception/deepfake_xception_lstm.onnx
TEXT_MODEL_PATH=./models/text_fraud_model.onnx
TEXT_VOCAB_PATH=./models/vocab.txt
ONNX_GPU_DEVICE_ID=0

# --- WebSocket ---
WS_HEARTBEAT_INTERVAL=30

# --- LLM ---
LLM_MODEL_NAME=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1

# --- 遥测（与 main.py 中环境变量可并存）---
ANONYMIZED_TELEMETRY=False
HUGGINGFACE_HUB_DISABLE_TELEMETRY=1
LANGCHAIN_TRACING_V2=false

# --- Email SMTP ---
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=你的邮箱@example.com
SMTP_PASSWORD=
SMTP_TLS=True
EMAIL_FROM=你的邮箱@example.com
EMAIL_FROM_NAME=AI反诈系统

# --- 智谱 ---
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
